{
	"name": "@repo/database",
	"private": true,
	"description": "TypeORM database package with entity schemas, DataSource factory, and migrations",
	"type": "module",
	"module": "src/index.ts",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"scripts": {
		"check:types": "tsc --noEmit",
		"test": "bun test",
		"migration:create": "bash scripts/create-migration.sh",
		"migration:generate": "bash scripts/generate-migration.sh",
		"migration:show": "bun --bun typeorm migration:show -d src/dataSource.ts",
		"migration:run": "bun --bun typeorm migration:run -d src/dataSource.ts",
		"migration:revert": "bun --bun typeorm migration:revert -d src/dataSource.ts"
	},
	"dependencies": {
		"@repo/shared-types": "workspace:*",
		"dotenv": "^17.4.2",
		"typeorm": "^0.3.28"
	},
	"devDependencies": {
		"@repo/typescript-config": "workspace:*",
		"@types/bun": "^1.3.13",
		"typescript": "^5.8.0"
	},
	"peerDependencies": {
		"mysql2": "^3.15.3"
	}
}
